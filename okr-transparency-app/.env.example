OKR_ADMIN_TOKEN=replace-with-internal-admin-token
OKR_LOCAL_ADMIN_USERNAME=admin
OKR_LOCAL_ADMIN_PASSWORD=replace-with-local-fallback-password
OKR_STORAGE=file
OKR_ALLOWED_GOOGLE_DOMAINS=unitxlabs.com
AUTH_SECRET=replace-with-random-secret
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret
FIRESTORE_PROJECT_ID=replace-with-gcp-project-id
FIRESTORE_DATABASE_ID=(default)
# Optional for local Firestore access outside GCP runtime:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
